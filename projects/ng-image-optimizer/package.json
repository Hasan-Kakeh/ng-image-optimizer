{
  "name": "ng-image-optimizer",
  "version": "0.0.4-beta",
  "description": "High-performance image optimization for Angular SSR. Includes a custom IMAGE_LOADER for NgOptimizedImage and Express middleware powered by sharp.",
  "license": "MIT",
  "type": "commonjs",
  "peerDependencies": {
    "@angular/common": ">=18.0.0",
    "@angular/core": ">=18.0.0"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Hasan-Kakeh/ng-image-optimizer"
  },
  "dependencies": {
    "tslib": "^2.3.0",
    "lru-cache": "^11.2.7"
  },
  "optionalDependencies": {
    "sharp": "^0.34.5"
  },
  "schematics": "./schematics/collection.json",
  "ng-add": {
    "save": "dependencies"
  },
  "exports": {
    "./schematics": "./schematics/collection.json"
  },
  "engines": {
    "node": ">=18 <23"
  },
  "scripts": {
    "prebuild": "ng build",
    "build": "tsc -p tsconfig.schematics.json",
    "postbuild": "copyfiles schematics/*/schema.json schematics/*/files/** schematics/collection.json ../../dist/ng-image-optimizer/"
  },
  "keywords": [
    "angular",
    "image",
    "optimizer",
    "sharp",
    "angular-ssr"
  ],
  "sideEffects": false
}
