{
  "$schema": "http://json-schema.org/draft-07/schema",
  "$id": "ng-add",
  "title": "my-lib ng-add schematic",
  "type": "object",
  "properties": {
    "project": {
      "type": "string",
      "description": "The name of the project.",
      "$default": {
        "$source": "projectName"
      }
    },
    "mode": {
      "type": "string",
      "description": "The optimization mode to use.",
      "enum": ["SSR", "AOT"],
      "default": "SSR",
      "x-prompt": {
        "message": "Which image optimization strategy would you like to use?",
        "type": "list",
        "items": [
          { "value": "SSR", "label": "SSR (Dynamic middleware using Express)" },
          { "value": "AOT", "label": "AOT (Static file path rewriting for pre-generated assets)" }
        ]
      }
    }
  },
  "required": []
}
